<Window x:Class="SimpleBrowserPicker.Views.PickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SimpleBrowserPicker.ViewModels"
        Title="Simple browser picker"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <!-- Outer border provides shadow + rounded corners -->
    <Border x:Name="RootBorder"
            Style="{StaticResource PickerWindowBorder}"
            MouseDown="RootBorder_MouseDown">

        <StackPanel MinWidth="340" MaxWidth="480">

            <!-- URL strip — domain emphasised, rest muted -->
            <Border Style="{StaticResource UrlStripBorder}">
                <TextBlock Style="{StaticResource UrlTextBlock}"
                           ToolTip="{Binding DisplayUrl}">
                    <Run Text="{Binding UrlScheme, Mode=OneTime}"
                         Foreground="{DynamicResource MutedBrush}"/><!--
                 --><Run Text="{Binding UrlDomain, Mode=OneTime}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource ForegroundBrush}"/><!--
                 --><Run Text="{Binding UrlSuffix, Mode=OneTime}"
                         Foreground="{DynamicResource MutedBrush}"/>
                </TextBlock>
            </Border>

            <!-- Browser list -->
            <ItemsControl ItemsSource="{Binding Browsers}"
                          Focusable="False"
                          Margin="8,4,8,4"
                          AlternationCount="100"
                          KeyboardNavigation.TabNavigation="Cycle"
                          KeyboardNavigation.DirectionalNavigation="Cycle">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource BrowserButton}"
                                Command="{Binding DataContext.OpenCommand,
                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Tag="{Binding}"
                                MouseEnter="BrowserButton_MouseEnter"
                                GotKeyboardFocus="BrowserButton_GotKeyboardFocus">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}"
                                       Width="24" Height="24"
                                       Margin="0,0,10,0"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BrowserNameText}"/>
                                <TextBlock VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           Style="{StaticResource ShortcutBadgeText}"
                                           Text="{Binding Path=(ItemsControl.AlternationIndex),
                                                  RelativeSource={RelativeSource AncestorType=ContentPresenter},
                                                  Converter={StaticResource IndexToShortcutConverter}}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- "Always use" checkbox -->
            <Border Visibility="{Binding AlwaysUseLabelVisible, Converter={StaticResource BoolToVis}}"
                    Margin="12,2,12,8">
                <CheckBox IsChecked="{Binding AlwaysUseChecked, Mode=TwoWay}"
                          Content="{Binding AlwaysUseLabel}"
                          Style="{StaticResource AlwaysUseCheckBox}"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
