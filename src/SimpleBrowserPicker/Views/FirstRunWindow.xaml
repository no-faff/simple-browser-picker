<Window x:Class="SimpleBrowserPicker.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Browser Picker – setup"
        Width="460" Height="330"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindow}">

    <StackPanel Margin="28">

        <TextBlock Text="Welcome to Simple Browser Picker"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10">
            Simple Browser Picker is not a browser — it's a link router. When
            you click a link anywhere on your computer, it pops up and lets you
            choose which browser or profile opens it.
        </TextBlock>

        <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,20">
            For this to work, Windows needs to treat it as your default browser.
            Click the button below, then select "Simple Browser Picker" in the
            Windows settings page that opens.
        </TextBlock>

        <!-- Set as default -->
        <Button Content="Set as default browser"
                Command="{Binding SetAsDefaultCommand}"
                FontSize="14" Padding="14,8"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

        <!-- Status message after clicking set as default -->
        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AccentBrush}"
                   Margin="0,0,0,10"
                   Visibility="{Binding StatusMessage,
                       Converter={StaticResource StringToVisConverter}}"/>

        <TextBlock Margin="0,4,0,0">
            <Hyperlink Command="{Binding SkipCommand}">Skip for now</Hyperlink>
        </TextBlock>

    </StackPanel>
</Window>
