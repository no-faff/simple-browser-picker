<Window x:Class="SimpleBrowserPicker.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple browser picker – setup"
        Width="480" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindow}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="28">

        <TextBlock Text="Welcome to Simple browser picker"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,14">
            Simple browser picker registers as your default browser. When any app opens
            a link, it shows a small popup so you can choose which browser — or browser
            profile — to use. You can also set rules to route specific domains to a
            particular browser automatically.
        </TextBlock>

        <!-- Detected browsers -->
        <TextBlock Text="Browsers detected on this machine:" FontWeight="Medium"
                   Margin="0,0,0,8"/>

        <Border Style="{StaticResource ListBorder}" MaxHeight="180" Margin="0,0,0,14">
            <ListBox ItemsSource="{Binding DetectedBrowsers}"
                     BorderThickness="0" Background="Transparent"
                     IsHitTestVisible="False">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,3">
                            <Image Source="{Binding Icon}"
                                   Width="20" Height="20" Margin="0,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Separator Margin="0,0,0,14"/>

        <!-- Set as default -->
        <Button Content="Set as default browser"
                Command="{Binding SetAsDefaultCommand}"
                FontSize="14" Padding="14,8"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

        <!-- Status message after clicking set as default -->
        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AccentBrush}"
                   Margin="0,0,0,10"
                   Visibility="{Binding StatusMessage,
                       Converter={StaticResource StringToVisConverter}}"/>

        <TextBlock Margin="0,4,0,0">
            <Hyperlink Command="{Binding SkipCommand}">Skip for now</Hyperlink>
        </TextBlock>

    </StackPanel>
</Window>
