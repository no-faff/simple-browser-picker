<Window x:Class="SimpleBrowserPicker.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Browser Picker – setup"
        Width="480" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <!-- Outer margin gives space for the drop shadow -->
    <Border Margin="10"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="8"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                              Opacity="0.22" Color="#000000"/>
        </Border.Effect>
        <Border CornerRadius="8" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- accent stripe -->
                    <RowDefinition Height="Auto"/>  <!-- close button row -->
                    <RowDefinition Height="*"/>     <!-- content -->
                </Grid.RowDefinitions>

                <!-- Accent stripe -->
                <Border Grid.Row="0" Height="2"
                        Background="{DynamicResource AccentBrush}"/>

                <!-- Close button -->
                <Button Grid.Row="1"
                        Style="{StaticResource CloseButton}"
                        HorizontalAlignment="Right"
                        Margin="0,8,12,0"
                        Click="CloseButton_Click"/>

                <!-- Content -->
                <StackPanel Grid.Row="2" Margin="28,4,28,28">

                    <TextBlock Text="Welcome to Simple Browser Picker"
                               FontSize="20" FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10">
                        Simple Browser Picker silently routes links to the right browser or
                        profile. Your current default browser will keep handling most links —
                        you just add rules for domains that should open elsewhere.
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,10">
                        To get started, register as your default browser below. Your previous
                        default will be saved automatically as the fallback. Then open settings
                        to add rules like "github.com → Vivaldi – Work".
                    </TextBlock>

                    <TextBlock TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,20"
                               Foreground="{DynamicResource MutedBrush}">
                        You can change the fallback browser and manage rules at any time
                        from the settings window.
                    </TextBlock>

                    <!-- Set as default -->
                    <Button Content="Set as default browser"
                            Command="{Binding SetAsDefaultCommand}"
                            FontSize="14" Padding="14,8"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"/>

                    <!-- Status message after clicking set as default -->
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,10"
                               Visibility="{Binding StatusMessage,
                                   Converter={StaticResource StringToVisConverter}}"/>

                    <TextBlock Margin="0,4,0,0" FontSize="12">
                        <Hyperlink Command="{Binding SkipCommand}">Skip for now</Hyperlink>
                    </TextBlock>

                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
