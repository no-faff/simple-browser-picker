<Window x:Class="SimpleBrowserPicker.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Browser Picker – settings"
        Width="660" Height="580"
        MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize">

    <!-- Outer margin gives space for the drop shadow -->
    <Border Margin="12"
            Background="{DynamicResource SurfaceBrush}"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8"
                              Opacity="0.4" Color="#000000"/>
        </Border.Effect>
        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- accent stripe -->
                    <RowDefinition Height="Auto"/>  <!-- title bar -->
                    <RowDefinition Height="*"/>     <!-- content -->
                </Grid.RowDefinitions>

                <!-- ============================================================
                     Accent stripe
                     ============================================================ -->
                <Border Grid.Row="0" Height="3"
                        Background="{DynamicResource AccentBrush}"/>

                <!-- ============================================================
                     Custom title bar with pill tabs
                     ============================================================ -->
                <Border Grid.Row="1" Padding="20,12,20,12"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Pill tabs — centred -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton x:Name="TabOpen" Content="Open"
                                         Style="{StaticResource PillTab}"
                                         IsChecked="True"
                                         Checked="PillTab_Checked"/>
                            <RadioButton x:Name="TabBrowsers" Content="Browsers"
                                         Style="{StaticResource PillTab}"
                                         Margin="4,0,0,0"
                                         Checked="PillTab_Checked"/>
                            <RadioButton x:Name="TabRules" Content="Rules"
                                         Style="{StaticResource PillTab}"
                                         Margin="4,0,0,0"
                                         Checked="PillTab_Checked"/>
                            <RadioButton x:Name="TabAbout" Content="About"
                                         Style="{StaticResource PillTab}"
                                         Margin="4,0,0,0"
                                         Checked="PillTab_Checked"/>
                        </StackPanel>

                        <!-- Close button — right -->
                        <Button Grid.Column="2"
                                Style="{StaticResource CloseButton}"
                                HorizontalAlignment="Right"
                                Click="CloseButton_Click"/>
                    </Grid>
                </Border>

                <!-- ============================================================
                     Tab content (native tab strip hidden)
                     ============================================================ -->
                <TabControl x:Name="MainTabs" Grid.Row="2"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">

                    <!-- ========================================================
                         Open tab — paste a URL and pick a browser
                         ======================================================== -->
                    <TabItem Header="Open" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="28,0,28,28">
                            <StackPanel>

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Open a link" Margin="0,0,0,4"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Paste a URL and click a browser to open it."/>

                                <!-- Address bar card -->
                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="OpenUrlTextBox"
                                                 Text="{Binding OpenUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="12.5"
                                                 VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" ToolTip="Paste from clipboard"
                                                Style="{StaticResource SecondaryButton}"
                                                Margin="8,0,0,0" Padding="8,5"
                                                Click="PasteClipboard_Click">
                                            <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                                  Fill="{DynamicResource ForegroundBrush}"
                                                  Stretch="Uniform" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Redirect info (shows when URL was unwrapped) -->
                                <TextBlock Visibility="{Binding ShowRedirectInfo,
                                               Converter={StaticResource BoolToVis}}"
                                           Margin="4,2,0,4"
                                           FontSize="12">
                                    <Run Text="↳ Redirects to "
                                         Foreground="{DynamicResource MutedBrush}"/>
                                    <Run Text="{Binding UnwrappedUrl, Mode=OneWay}"
                                         Foreground="{DynamicResource AccentBrush}"/>
                                </TextBlock>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,24">
                                    <Button Content="Security check"
                                            Command="{Binding SecurityCheckCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,6" FontSize="12"
                                            ToolTip="Open Google's transparency report for this URL"/>
                                </StackPanel>

                                <!-- Browser list -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Choose a browser" Margin="0,0,0,4"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Click one to open the link above."/>

                                <Border Style="{StaticResource CardBorder}">
                                    <ItemsControl ItemsSource="{Binding Browsers}" Focusable="False">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource BrowserButton}"
                                                        Command="{Binding DataContext.OpenInBrowserCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Image Source="{Binding Icon}"
                                                               Width="24" Height="24"
                                                               Margin="0,0,10,0"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13.5"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ========================================================
                         Browsers tab
                         ======================================================== -->
                    <TabItem Header="Browsers" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="28,0,28,28">
                            <StackPanel>

                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Your browsers" Margin="0,0,0,4"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="These were detected automatically. Click one to rename it or change its arguments."/>

                                <!-- Filter -->
                                <Grid Margin="0,0,0,10">
                                    <TextBox Text="{Binding BrowserFilter, UpdateSourceTrigger=PropertyChanged}"
                                             x:Name="BrowserFilterBox"/>
                                    <TextBlock Text="Search browsers…"
                                               IsHitTestVisible="False"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding Text, ElementName=BrowserFilterBox,
                                                   Converter={StaticResource EmptyToVisConverter}}"/>
                                </Grid>

                                <!-- Detected browsers card -->
                                <Border Style="{StaticResource CardBorder}">
                                    <ListBox ItemsSource="{Binding Browsers}"
                                             SelectedItem="{Binding SelectedBrowser}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MaxHeight="200">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,4">
                                                    <Image Source="{Binding Icon}"
                                                           Width="22" Height="22" Margin="0,0,10,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                               FontSize="13.5"/>
                                                    <TextBlock Text=" (custom)" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource MutedBrush}"
                                                               FontSize="12"
                                                               Visibility="{Binding IsCustom,
                                                                   Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>

                                <!-- Reorder + refresh -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                                    <Button Content="↑" Command="{Binding MoveBrowserUpCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="10,5"
                                            ToolTip="Move up" Margin="0,0,4,0"/>
                                    <Button Content="↓" Command="{Binding MoveBrowserDownCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="10,5"
                                            ToolTip="Move down" Margin="0,0,8,0"/>
                                    <Button Content="Re-detect" Command="{Binding RefreshBrowsersCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,6"/>
                                </StackPanel>

                                <!-- Edit selected browser -->
                                <Border Style="{StaticResource CardBorder}" Margin="0,20,0,0"
                                        Visibility="{Binding HasSelectedBrowser,
                                            Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Edit browser" FontSize="14" FontWeight="SemiBold"
                                                   Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                                       VerticalAlignment="Center" Margin="0,4,8,4"/>
                                            <TextBox   Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding EditBrowserName, UpdateSourceTrigger=PropertyChanged}"
                                                       Margin="0,4"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Path"
                                                       VerticalAlignment="Center" Margin="0,4,8,4"
                                                       Foreground="{DynamicResource MutedBrush}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding EditBrowserPath, Mode=OneWay}"
                                                       FontFamily="Consolas" FontSize="11.5"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,4"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding EditBrowserPath}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Extra args"
                                                       VerticalAlignment="Center" Margin="0,4,8,4"/>
                                            <TextBox   Grid.Row="2" Grid.Column="1"
                                                       Text="{Binding EditBrowserArgs, UpdateSourceTrigger=PropertyChanged}"
                                                       Margin="0,4"/>

                                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Orientation="Horizontal" HorizontalAlignment="Right"
                                                        Margin="0,10,0,0">
                                                <Button Content="Save changes" Command="{Binding SaveBrowserEditCommand}"
                                                        Padding="14,7" Margin="0,0,6,0"/>
                                                <Button Content="Remove" Command="{Binding RemoveBrowserCommand}"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Padding="14,7"
                                                        Visibility="{Binding SelectedBrowser.IsCustom,
                                                            Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Add custom browser -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Add a custom browser" Margin="0,28,0,4"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="If a browser wasn't detected automatically, you can add it here."/>
                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                        <TextBox   Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                   Text="{Binding CustomBrowserName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                        <TextBox   Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding CustomBrowserExe, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>
                                        <Button    Grid.Row="1" Grid.Column="2" Content="Browse…" Command="{Binding BrowseExeCommand}"
                                                   Style="{StaticResource SecondaryButton}" Margin="6,4,0,4" Padding="12,6"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Extra args" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                        <Grid      Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4">
                                            <TextBox Text="{Binding CustomBrowserArgs, UpdateSourceTrigger=PropertyChanged}"
                                                     x:Name="ArgsTextBox"/>
                                            <TextBlock Text="optional, e.g. --incognito"
                                                       IsHitTestVisible="False"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="{Binding Text, ElementName=ArgsTextBox,
                                                           Converter={StaticResource EmptyToVisConverter}}"/>
                                        </Grid>

                                        <Button    Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                   Content="Add browser" Command="{Binding AddCustomBrowserCommand}"
                                                   HorizontalAlignment="Right" Margin="0,10,0,0"
                                                   Padding="14,7"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ========================================================
                         Rules tab
                         ======================================================== -->
                    <TabItem Header="Rules" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="28,0,28,28">
                            <StackPanel>

                                <!-- ── Default behaviour ── -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Default behaviour"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="What happens when you click a link that doesn't match any rule below."/>

                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Always ask me" FontSize="13.5" FontWeight="SemiBold"/>
                                            <TextBlock Text="Show the browser picker for every link, even if a default is set."
                                                       FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,16,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding AlwaysAsk}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10"
                                        Visibility="{Binding ShowFallbackSection,
                                            Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="Default browser" FontSize="13.5" FontWeight="SemiBold"/>
                                        <TextBlock Text="When no rule matches, open the link silently in this browser — no popup."
                                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                                   TextWrapping="Wrap" Margin="0,2,0,10"/>
                                        <ComboBox ItemsSource="{Binding Browsers}"
                                                  SelectedItem="{Binding FallbackBrowser}"
                                                  DisplayMemberPath="Name"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,28">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Pause all rules" FontSize="13.5" FontWeight="SemiBold"/>
                                            <TextBlock Text="Temporarily ignore all rules below so you can test or debug. Your rules are kept."
                                                       FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,16,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding SuspendRules}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- ── Rules list ── -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Routing rules"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Send specific websites to a specific browser. Rules are checked top to bottom — the first match wins. Click a rule to edit it."/>

                                <!-- Filter -->
                                <Grid Margin="0,0,0,10">
                                    <TextBox Text="{Binding RuleFilter, UpdateSourceTrigger=PropertyChanged}"
                                             x:Name="RuleFilterBox"/>
                                    <TextBlock Text="Search rules…"
                                               IsHitTestVisible="False"
                                               Foreground="{DynamicResource MutedBrush}"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Visibility="{Binding Text, ElementName=RuleFilterBox,
                                                   Converter={StaticResource EmptyToVisConverter}}"/>
                                </Grid>

                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <!-- Empty state -->
                                        <StackPanel HorizontalAlignment="Center" Margin="0,12"
                                                    Visibility="{Binding HasNoRules,
                                                        Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="No rules yet"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                            <TextBlock Text="Add one below to route a website to a specific browser."
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <ListBox ItemsSource="{Binding Rules}"
                                                 SelectedItem="{Binding SelectedRule}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 MaxHeight="180">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="4,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Domain}"
                                                                   FontFamily="Consolas" FontSize="13"/>
                                                        <TextBlock Grid.Column="1" Text="→"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="14"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding BrowserName}"
                                                                   FontSize="13"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                                    <Button Content="↑" Command="{Binding MoveRuleUpCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="10,5"
                                            ToolTip="Move up (higher priority)" Margin="0,0,4,0"/>
                                    <Button Content="↓" Command="{Binding MoveRuleDownCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="10,5"
                                            ToolTip="Move down (lower priority)" Margin="0,0,8,0"/>
                                    <Button Content="Delete rule" Command="{Binding DeleteRuleCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="12,6"/>
                                </StackPanel>

                                <!-- ── Add rule ── -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Add a rule" Margin="0,28,0,4"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Type a domain or URL pattern and choose which browser to open it in. Use *.example.com for subdomains, or example.com/path/* for path matching."/>

                                <Border Style="{StaticResource CardBorder}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Pattern"
                                                   VerticalAlignment="Center" Margin="0,4,8,4"/>
                                        <Grid      Grid.Row="0" Grid.Column="1" Margin="0,4">
                                            <TextBox Text="{Binding NewRuleDomain, UpdateSourceTrigger=PropertyChanged}"
                                                     x:Name="DomainTextBox"/>
                                            <TextBlock Text="e.g. github.com, *.corp.com, github.com/gist/*"
                                                       IsHitTestVisible="False"
                                                       Foreground="{DynamicResource MutedBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="{Binding Text, ElementName=DomainTextBox,
                                                           Converter={StaticResource EmptyToVisConverter}}"/>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Browser"
                                                   VerticalAlignment="Center" Margin="0,4,8,4"/>
                                        <ComboBox  Grid.Row="1" Grid.Column="1"
                                                   ItemsSource="{Binding Browsers}"
                                                   SelectedItem="{Binding NewRuleBrowser}"
                                                   DisplayMemberPath="Name"
                                                   Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="Leave empty to always show the picker for this domain."
                                                   FontSize="12" Foreground="{DynamicResource MutedBrush}"
                                                   TextWrapping="Wrap" Margin="0,2,0,4"/>

                                        <Button    Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Content="Add rule" Command="{Binding AddRuleCommand}"
                                                   HorizontalAlignment="Right" Margin="0,10,0,0"
                                                   Padding="14,7"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ========================================================
                         About tab
                         ======================================================== -->
                    <TabItem Header="About" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="28,0,28,28">
                            <StackPanel>

                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock FontSize="22" FontWeight="SemiBold"
                                                   Margin="0,0,0,4">
                                            <Run Text="Simple Browser Picker"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource MutedBrush}"
                                                   FontSize="13" Margin="0,0,0,12">
                                            <Run Text="Version "/>
                                            <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                            <Run Text=" · Part of the"/>
                                            <Run Text=" No Faff " FontWeight="SemiBold"/>
                                            <Run Text="suite"/>
                                        </TextBlock>
                                        <TextBlock FontSize="13">
                                            <Hyperlink NavigateUri="https://github.com/no-faff/simple-browser-picker"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                github.com/no-faff/simple-browser-picker
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Registration -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Registration"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Simple Browser Picker needs to be your default browser so it can intercept links."/>

                                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RegistrationStatus}"
                                                   FontSize="13"
                                                   Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Register as default browser"
                                                    Command="{Binding RegisterCommand}"
                                                    Padding="14,7" Margin="0,0,8,0"/>
                                            <Button Content="Unregister"
                                                    Command="{Binding UnregisterCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Padding="14,7"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Config backup -->
                                <TextBlock Style="{StaticResource SectionHeader}"
                                           Text="Back up your settings"/>
                                <TextBlock Style="{StaticResource SectionDescription}"
                                           Text="Export your rules and settings to a file, or restore from a previous backup."/>

                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Export"
                                                Command="{Binding ExportConfigCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="14,7" Margin="0,0,8,0"/>
                                        <Button Content="Import"
                                                Command="{Binding ImportConfigCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="14,7"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>
    </Border>
</Window>
